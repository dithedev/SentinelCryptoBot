# Copy to .env and fill in your own values. Never commit .env.
#
# Your .env does not need every key below. Required runtime keys are marked.
# Optional keys fall back to defaults from app/core/constants.py.

# --- Required for bot, API, and worker ---
BOT_TOKEN=123456:replace-with-your-telegram-bot-token
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sentinel_crypto

# --- Optional app settings (defaults exist) ---
APP_NAME=Sentinel Crypto
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Optional provider URLs (defaults exist) ---
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
GOPLUS_BASE_URL=https://api.gopluslabs.io/api/v1

# --- Optional worker tuning (defaults exist) ---
PRICE_CHECK_INTERVAL_SECONDS=60
WHALE_CHECK_INTERVAL_SECONDS=120
WHALE_PROVIDER=simulated
WHALE_SIMULATED_EVENTS_PER_CYCLE=1
TELEGRAM_SEND_RATE_PER_SECOND=20

# --- Optional throttling (defaults exist, per process) ---
BOT_USER_MIN_INTERVAL_SECONDS=1.0
MINIAPP_API_REQUESTS_PER_MINUTE=60

# --- Optional Mini App button in the bot menu ---
# Telegram requires HTTPS in production, for example:
# MINIAPP_URL=https://your-app.onrender.com/miniapp
MINIAPP_URL=

# --- Tests only (pytest -m db), not used by runtime Settings ---
DATABASE_URL_TEST=postgresql+asyncpg://postgres:password@localhost:5432/sentinel_crypto_test
